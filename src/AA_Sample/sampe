    color: $text-secondary;
    text-decoration: none;
    padding: 14px 20px;
    border-radius: $radius-xl;
    border: 1px solid $border;
    transition: $transition;

    &:hover {
      color: $text-primary;
      border-color: rgba(255,255,255,0.2);
      background: rgba(255,255,255,0.05);
    }
  }

  // Stats
  &__stats {
    display: flex;
    gap: 32px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s 0.55s ease, transform 0.5s 0.55s ease;

    &--visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  &__stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: relative;

    &:not(:last-child)::after {
      content: '';
      position: absolute;
      right: -16px;
      top: 50%;
      transform: translateY(-50%);
      width: 1px;
      height: 36px;
      background: $border;
    }
  }

  &__stat-value {
    font-family: $font-display;
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
  }

  &__stat-label {
    font-size: 0.78rem;
    color: $text-muted;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  // Visual Side
  &__visual {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    opacity: 0;
    transform: translateX(40px);
    transition: opacity 0.6s 0.3s ease, transform 0.6s 0.3s ease;

    &--visible {
      opacity: 1;
      transform: translateX(0);
    }

    @media (max-width: 1024px) {
      display: none;
    }
  }

  &__visual-card {
    background: rgba(17,24,39,0.9);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: $radius-lg;
    padding: 24px;
    width: 380px;
    backdrop-filter: blur(20px);
    box-shadow: 0 30px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.05);
    animation: float 6s ease-in-out infinite;
  }

  &__visual-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid $border;
  }

  &__visual-dots {
    display: flex;
    gap: 6px;

    span {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: rgba(255,255,255,0.2);

      &:nth-child(1) { background: #ff5f57; }
      &:nth-child(2) { background: #febc2e; }
      &:nth-child(3) { background: #28c840; }
    }
  }

  &__visual-label {
    font-size: 0.8rem;
    color: $text-muted;
    font-weight: 500;
  }

  &__visual-body {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  &__visual-stat-row {
    display: flex;
    gap: 16px;
  }

  &__visual-mini-stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
    text-align: center;

    span {
      font-size: 0.72rem;
      color: $text-muted;
    }

    strong {
      font-size: 1rem;
      font-weight: 700;
      color: $text-primary;
    }
  }

  &__visual-mini-bar {
    width: 100%;
    height: 4px;
    background: rgba(255,255,255,0.08);
    border-radius: 2px;
    overflow: hidden;

    &::after {
      content: '';
      display: block;
      height: 100%;
      width: var(--fill);
      background: var(--accent);
      border-radius: 2px;
      animation: shimmer 2s ease infinite;
    }
  }

  &__visual-avatar-row {
    display: flex;
    align-items: center;
    gap: -8px;
    padding: 12px 0;
    border-top: 1px solid $border;
    border-bottom: 1px solid $border;
  }

  &__visual-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), $accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    color: white;
    border: 2px solid $bg-card;
    margin-left: calc(var(--av-i) * -8px);
    transition: transform 0.2s;

    &:hover {
      transform: translateY(-4px) scale(1.1);
      z-index: 10;
    }
  }

  &__visual-more {
    margin-left: 4px;
    font-size: 0.78rem;
    color: $text-muted;
    font-weight: 600;
  }

  &__visual-progress-block {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.8rem;
    color: $text-secondary;
  }

  &__visual-progress-bar {
    flex: 1;
    height: 6px;
    background: rgba(255,255,255,0.08);
    border-radius: 3px;
    overflow: hidden;
  }

  &__visual-progress-fill {
    height: 100%;
    width: var(--width);
    background: linear-gradient(90deg, var(--accent), $accent);
    border-radius: 3px;
  }

  // Floating badges
  &__badge {
    position: absolute;
    background: rgba(17,24,39,0.95);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: $radius-md;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    color: $text-primary;
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.3);

    &--1 {
      top: 20px;
      right: -20px;
      animation: float 4s ease-in-out 1s infinite;
    }

    &--2 {
      bottom: 30px;
      left: -20px;
      animation: float 5s ease-in-out 0.5s infinite;
    }
  }

  // Controls
  &__controls {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 20px;
    z-index: 10;
  }

  &__arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    border: 1px solid $border;
    color: $text-secondary;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: $transition;
    font-size: 1.1rem;

    &:hover {
      background: var(--accent);
      border-color: var(--accent);
      color: $bg-dark;
      transform: scale(1.1);
    }
  }

  &__indicators {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  &__indicator {
    position: relative;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;

    &-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255,255,255,0.25);
      transition: $transition;
      display: block;
    }

    &--active &-dot {
      background: var(--accent);
    }
  }

  &__progress-ring {
    position: absolute;
    inset: 0;
    width: 30px;
    height: 30px;
    transform: rotate(-90deg);
  }

  &__progress-track {
    fill: none;
    stroke: rgba(255,255,255,0.1);
    stroke-width: 2;
  }

  &__progress-fill {
    fill: none;
    stroke: var(--accent);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-dasharray: 100.5;
    stroke-dashoffset: calc(100.5 - (100.5 * var(--progress) / 100));
    transition: stroke-dashoffset 0.1s linear;
  }

  // Scroll hint
  &__scroll-hint {
    position: absolute;
    bottom: 40px;
    right: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0.4;

    @media (max-width: 768px) { display: none; }
  }

  &__scroll-mouse {
    width: 24px;
    height: 36px;
    border: 2px solid $text-muted;
    border-radius: 12px;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  &__scroll-wheel {
    width: 4px;
    height: 8px;
    background: $text-muted;
    border-radius: 2px;
    animation: float 2s ease-in-out infinite;
  }

  &__scroll-hint span {
    font-size: 0.65rem;
    color: $text-muted;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    writing-mode: vertical-rl;
  }
}

